# Exchange credentials (leave empty for paper trading)
EXCHANGE=binance
API_KEY=
API_SECRET=

# Trading mode: paper | live
MODE=paper

# EVM wallet (for venue: evm in config.yaml)
EVM_CHAIN=base
EVM_PRIVATE_KEY=
EVM_RPC_URL=

# MetaTrader 5 bridge (for venue: mt5 in config.yaml)
# HOST/PORT point at the remote box running the MT5 terminal + mt5linux server.
# LOGIN/PASSWORD/SERVER are your broker DEMO account credentials — fill these
# in yourself; they are read from here and never leave your machine + the
# bridge. Leave LOGIN empty to use whatever account the remote terminal is
# already logged into.
MT5_HOST=127.0.0.1
MT5_PORT=18812
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# Hyperliquid DeFi wallet (for hyperwallet.py). Optional — `create` writes a
# gitignored wallet_testnet.json instead. Set this to use an existing key.
# TESTNET keys only; never put a real-money key here.
HL_PRIVATE_KEY=

# Tron address to scan for TRC20 USDT in scan_deposits.py. Optional — Tron
# addresses use a different format (base58, starts with "T") than the EVM
# wallet above, so they can't share an address.
TRON_ACCOUNT_ADDRESS=
